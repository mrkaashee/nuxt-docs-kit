{
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "editor.quickSuggestions": {
    "strings": "on"
  },
  "tailwindCSS.classAttributes": ["class", "ui"],
  "tailwindCSS.classFunctions": ["defineAppConfig"],

  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/.nuxt": false,
    "**/.output": false,
    "**/dist": false
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/.nuxt": true,
    "**/.output": true,
    "**/package-lock.json": true,
    "**/bun.lock": true
  },
  "explorer.compactFolders": false,
  "vue.autoInsert.dotValue": true,
  "workbench.colorTheme": "GitHub Dark Default",
  "cSpell.words": [
    "Attendence",
    "comark",
    "gapcursor",
    "heroicons",
    "iconify",
    "libsql",
    "llms",
    "lucide",
    "nuxt",
    "nuxthub",
    "nuxtjs",
    "prefs",
    "prosemirror",
    "qarpeo",
    "Slideover",
    "superadmin",
    "unovis",
    "vuedraggable",
    "vueuse"
  ],
  "todohighlight.isEnable": true,
  "todohighlight.isCaseSensitive": true,
  "todohighlight.keywords": [
    {
      "text": "TODO:",
      "color": "#FFFFFF",
      "backgroundColor": "#007ACC",
      "overviewRulerColor": "#007ACC",
      "isWholeLine": false
    },
    {
      "text": "FIXME:",
      "color": "#FFFFFF",
      "backgroundColor": "#FF5555",
      "overviewRulerColor": "#FF5555",
      "isWholeLine": false
    },
    {
      "text": "BUG:",
      "color": "#FFFFFF",
      "backgroundColor": "#D70040",
      "overviewRulerColor": "#D70040",
      "isWholeLine": false
    },
    {
      "text": "DEBUG:",
      "color": "#000000",
      "backgroundColor": "#32CD32",
      "overviewRulerColor": "#32CD32",
      "isWholeLine": false
    },
    {
      "text": "NOTE:",
      "color": "#000000",
      "backgroundColor": "#FFD700",
      "overviewRulerColor": "#FFD700",
      "isWholeLine": false
    },
    {
      "text": "REVIEW:",
      "color": "#000000",
      "backgroundColor": "#FF8C00",
      "overviewRulerColor": "#FF8C00",
      "isWholeLine": false
    },
    {
      "text": "HACK:",
      "color": "#FFFFFF",
      "backgroundColor": "#C71585",
      "overviewRulerColor": "#C71585",
      "isWholeLine": false
    },
    {
      "text": "OPTIMIZE:",
      "color": "#FFFFFF",
      "backgroundColor": "#20B2AA",
      "overviewRulerColor": "#20B2AA",
      "isWholeLine": false
    },
    {
      "text": "CHORE:",
      "color": "#000000",
      "backgroundColor": "#ADFF2F",
      "overviewRulerColor": "#ADFF2F",
      "isWholeLine": false
    },
    {
      "text": "QUESTION:",
      "color": "#FFFFFF",
      "backgroundColor": "#800080",
      "overviewRulerColor": "#800080",
      "isWholeLine": false
    },
    {
      "text": "TEMP:",
      "color": "#000000",
      "backgroundColor": "#FFA07A",
      "overviewRulerColor": "#FFA07A",
      "isWholeLine": false
    },
    {
      "text": "WIP:",
      "color": "#FFFFFF",
      "backgroundColor": "#4682B4",
      "overviewRulerColor": "#4682B4",
      "isWholeLine": false
    }
  ],

  "js/ts.experimental.useTsgo": false,
  "npm.scriptRunner": "vp",
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "oxc.fmt.configPath": "./vite.config.ts",
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "explicit"
  },
  "[javascript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  }
}
